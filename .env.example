# ===========================================
# Hermes WeCom Excel Assistant 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值

# ---------------------------
# 企业微信回调配置 (必填)
# ---------------------------
WECOM_CALLBACK_CORP_ID=your-corp-id
WECOM_CALLBACK_CORP_SECRET=your-corp-secret
WECOM_CALLBACK_AGENT_ID=1000002
WECOM_CALLBACK_TOKEN=your-token
WECOM_CALLBACK_ENCODING_AES_KEY=your-43-char-encoding-aes-key
WECOM_CALLBACK_ALLOWED_USERS=user1,user2

# ---------------------------
# Hermes LLM 配置 (必填)
# ---------------------------
HERMES_PROVIDER=openrouter
HERMES_MODEL=anthropic/claude-3-sonnet
OPENROUTER_API_KEY=sk-or-xxx

# ---------------------------
# Terminal 安全配置 (P0 必填)
# ---------------------------
TERMINAL_BACKEND=docker
TERMINAL_DOCKER_IMAGE=python:3.11-slim
# 网络隔离 (安全关键)
TERMINAL_NETWORK_DISABLED=true
# 执行超时 (秒)
TERMINAL_TIMEOUT=300
# 只读根文件系统
TERMINAL_READ_ONLY_ROOT=true
# 进程数限制
TERMINAL_MAX_PROCESSES=100
# 容器资源限制
TERMINAL_CONTAINER_CPU=1
TERMINAL_CONTAINER_MEMORY=2048

# ---------------------------
# MinIO 对象存储配置
# ---------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your-secure-password
MINIO_BUCKET=excel-files

# ---------------------------
# 可选配置
# ---------------------------
# 日志级别
LOG_LEVEL=INFO
# 文件过期天数
FILE_EXPIRE_DAYS=7
# CORS 允许的域名（生产环境必须配置具体域名）
CORS_ORIGINS=https://your-domain.com,https://wxwork://
