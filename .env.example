# ===========================================
# Hermes WeCom Excel Assistant 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值
#
# 开发路径说明：
# - 本地开发：只需配置 [MinIO] + [LLM] 部分
# - 测试企业：配置全部，企微参数从测试企业获取
# - 正式部署：配置全部，企微参数从企业管理员获取
#
# 详细指南：docs/LOCAL_DEV_GUIDE.md

# ===========================================
# [本地开发必须] MinIO 对象存储配置
# ===========================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your-secure-password
MINIO_BUCKET=excel-files

# ===========================================
# [本地开发必须] Hermes LLM 配置
# ===========================================
# 方式 1: OpenRouter（推荐，200+ 模型可选）
HERMES_PROVIDER=openrouter
HERMES_MODEL=anthropic/claude-3-sonnet
OPENROUTER_API_KEY=sk-or-xxx

# 方式 2: OpenAI 兼容自定义端点（类 OpenAI 协议）
# 适用于：本地 VLLM/SGLang、自建服务、第三方兼容 API
# HERMES_PROVIDER=openai
# HERMES_MODEL=your-model-name
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://your-custom-url/v1

# 方式 3: 其他提供商（详见 Hermes 文档）
# DeepSeek:    DEEPSEEK_API_KEY + DEEPSEEK_BASE_URL
# 智谱 GLM:     GLM_API_KEY + GLM_BASE_URL
# Kimi/月之暗面: KIMI_API_KEY + KIMI_BASE_URL
# Mistral:     MISTRAL_API_KEY + MISTRAL_BASE_URL
# xAI/Grok:    XAI_API_KEY + XAI_BASE_URL
# Google/Gemini: GOOGLE_API_KEY + GEMINI_BASE_URL

# ===========================================
# [企微集成必须] 企业微信回调配置
# ===========================================
# 来源：企业微信管理后台 → 自建应用 → 接收消息 → 设置 API 接收
# 
# 获取方式：
# - Corp ID：管理后台 → 我的企业 → 企业信息 → 企业ID
# - Corp Secret：管理工具 → 通讯录同步 → Secret（或应用 Secret）
# - Agent ID：自建应用详情页 → AgentId
# - Token：自己设置 3-32 字符
# - EncodingAESKey：点击"随机获取"，系统生成 43 字符
# - Allowed Users：通讯录成员账号（userid），逗号分隔
#
# 测试企业注册（5分钟获得管理员权限）：
# https://work.weixin.qq.com/wework_admin/register_wework?from=test_wework
WECOM_CALLBACK_CORP_ID=your-corp-id
WECOM_CALLBACK_CORP_SECRET=your-corp-secret
WECOM_CALLBACK_AGENT_ID=1000002
WECOM_CALLBACK_TOKEN=your-token
WECOM_CALLBACK_ENCODING_AES_KEY=your-43-char-encoding-aes-key
WECOM_CALLBACK_ALLOWED_USERS=user1,user2

# ===========================================
# [企微集成必须] Terminal 安全配置
# ===========================================
TERMINAL_BACKEND=docker
TERMINAL_DOCKER_IMAGE=python:3.11-slim
# 网络隔离 (安全关键)
TERMINAL_NETWORK_DISABLED=true
# 执行超时 (秒)
TERMINAL_TIMEOUT=300
# 只读根文件系统
TERMINAL_READ_ONLY_ROOT=true
# 进程数限制
TERMINAL_MAX_PROCESSES=100
# 容器资源限制
TERMINAL_CONTAINER_CPU=1
TERMINAL_CONTAINER_MEMORY=2048

# ===========================================
# [可选] 其他配置
# ===========================================
# 日志级别
LOG_LEVEL=INFO
# 文件过期天数
FILE_EXPIRE_DAYS=7
# CORS 允许的域名
# - 本地开发：http://localhost:* 或留空
# - 生产环境：必须配置具体域名，如 https://your-domain.com
CORS_ORIGINS=https://your-domain.com,https://wxwork://